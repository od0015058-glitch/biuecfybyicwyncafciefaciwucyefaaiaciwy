#. ❌ ایجاد فاکتور با خطا مواجه شد. لطفاً دوباره تلاش کنید.
#: strings.py:charge_invoice_error
msgid "charge_invoice_error"
msgstr "❌ Invoice creation failed. Please try again."

#. 🧾 **فاکتور شارژ حساب**
#. 
#. مبلغ شارژ خالص: `${amount}`
#. ارز انتخابی: `{currency}`
#. 
#. مبلغ قابل پرداخت (با احتساب کارمزد شبکه و درگاه):
#. **`{pay_amount}`**
#. 
#. آدرس واریز:
#. `{pay_address}`
#. 
#. ⚠️ لطفاً دقیقاً همین مبلغ را واریز کنید.
#. 🕒 برای دریافت با نرخ بالا تا ۶۰ دقیقه فرصت دارید. پس از آن پرداخت تا ۷ روز با نرخ لحظه‌ای دنبال می‌شود. بعد از ۷ روز باید فاکتور جدید بسازید.
#: strings.py:charge_invoice_text
msgid "charge_invoice_text"
msgstr ""
"🧾 **Top-up invoice**\n"
"\n"
"Net amount: `${amount}`\n"
"Currency: `{currency}`\n"
"\n"
"Total payable (network + gateway fees included):\n"
"**`{pay_amount}`**\n"
"\n"
"Send to:\n"
"`{pay_address}`\n"
"\n"
"⚠️ Send EXACTLY this amount.\n"
"🕒 The quoted rate is locked for ~60 minutes. After that the payment is still tracked at the live rate for up to 7 days. If you haven't paid by then, just create a new invoice."

#. ❌ مبلغ شما برای {currency} کمتر از حداقل قابل پرداخت است.
#. لطفاً مبلغ بیشتری وارد کنید یا ارز دیگری (مثلاً USDT-TRC20) انتخاب کنید.
#: strings.py:charge_min_amount_unknown
msgid "charge_min_amount_unknown"
msgstr ""
"❌ Your amount is below the minimum payable for {currency}.\n"
"Please try a higher amount, or pick a cheaper currency (e.g. USDT-TRC20)."

#. ❌ حداقل مبلغ قابل پرداخت برای {currency} برابر است با ${min_usd:.2f}.
#. لطفاً مبلغ بیشتری وارد کنید یا ارز دیگری انتخاب کنید.
#: strings.py:charge_min_amount_with_min
msgid "charge_min_amount_with_min"
msgstr ""
"❌ The minimum payable amount for {currency} is ${min_usd:.2f}.\n"
"Please pick a higher amount or a different currency."

#. ❌ حداقل مبلغ قابل پرداخت برای {currency} برابر است با ${min_usd:.2f}.
#. 💡 برای پرداخت ${amount_usd:.2f} می‌توانید از {alt_currency} استفاده کنید.
#: strings.py:charge_min_amount_with_min_and_alt
msgid "charge_min_amount_with_min_and_alt"
msgstr ""
"❌ The minimum payable amount for {currency} is ${min_usd:.2f}.\n"
"💡 You can pay ${amount_usd:.2f} with {alt_currency} instead."

#. 💰 مبلغ شارژ را انتخاب کنید:
#. 
#. 💡 حداقل مبلغ: $2
#. ⚠️ برخی ارزها به دلیل کارمزد شبکه حداقل بالاتری دارند.
#: strings.py:charge_pick_amount
msgid "charge_pick_amount"
msgstr ""
"💰 Choose a top-up amount:\n"
"\n"
"💡 Minimum: $2\n"
"⚠️ Some currencies have a higher minimum due to network fees."

#. 💰 مبلغ: **${amount}**
#. 
#. 🪙 ارز خود را انتخاب کنید:
#: strings.py:charge_pick_currency
msgid "charge_pick_currency"
msgstr ""
"💰 Amount: **${amount}**\n"
"\n"
"🪙 Pick your currency:"

#. 💵 مبلغ {entered_toman:,.0f} تومان ≈ ${amount:.2f} ثبت شد.
#. (نرخ تبدیل: هر دلار ≈ {rate_toman:,.0f} تومان)
#. 
#. 🪙 روش پرداخت را انتخاب کنید:
#: strings.py:charge_toman_amount_saved
msgid "charge_toman_amount_saved"
msgstr ""
"💵 {entered_toman:,.0f} TMN ≈ ${amount:.2f} saved.\n"
"(Conversion rate: 1 USD ≈ {rate_toman:,.0f} TMN)\n"
"\n"
"🪙 Pick a payment method:"

#. ❌ لطفاً یک عدد معتبر وارد کنید (مثال: 400000 یا ۴۰۰٬۰۰۰).
#: strings.py:charge_toman_invalid
msgid "charge_toman_invalid"
msgstr "❌ Please enter a valid number (example: 400000 or ۴۰۰٬۰۰۰)."

#. ❌ حداقل معادل $2 است (≈ {min_toman:,.0f} تومان). شما وارد کردید: {entered_toman:,.0f} تومان.
#: strings.py:charge_toman_min_error
msgid "charge_toman_min_error"
msgstr ""
"❌ Minimum is the equivalent of $2 (≈ {min_toman:,.0f} TMN). You entered: {entered_toman:,.0f} TMN."

#. ⚠️ در حال حاضر نرخ زنده دلار به تومان در دسترس نیست.
#. لطفاً چند دقیقه بعد دوباره تلاش کنید یا مبلغ را به دلار وارد کنید.
#: strings.py:charge_toman_no_rate
msgid "charge_toman_no_rate"
msgstr ""
"⚠️ The live USD→Toman rate is not available right now.\n"
"Please try again in a few minutes, or enter the amount in USD instead."

#. ✏️ مبلغ مورد نظر خود را به تومان وارد کنید:
#. 
#. 💡 نرخ فعلی: هر دلار ≈ {rate_toman:,.0f} تومان
#. 💡 حداقل معادل: $2 (≈ {min_toman:,.0f} تومان)
#. 💡 مثال: 400000 یا ۴۰۰٬۰۰۰
#: strings.py:charge_toman_prompt
msgid "charge_toman_prompt"
msgstr ""
"✏️ Enter the amount you want to top up, in Toman:\n"
"\n"
"💡 Current rate: 1 USD ≈ {rate_toman:,.0f} TMN\n"
"💡 Minimum: $2 (≈ {min_toman:,.0f} TMN)\n"
"💡 Examples: 400000 or ۴۰۰٬۰۰۰"

