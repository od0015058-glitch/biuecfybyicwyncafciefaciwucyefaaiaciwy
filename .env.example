# Telegram bot token from @BotFather
BOT_TOKEN=

# OpenRouter API key (https://openrouter.ai/settings/keys)
OPENROUTER_API_KEY=

# NowPayments API key + IPN secret (Store Settings -> API keys / IPN settings)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# Public base URL where this bot's webhook is reachable (use HTTPS in production).
# The IPN endpoint will be ${WEBHOOK_BASE_URL}/nowpayments-webhook
WEBHOOK_BASE_URL=

# Port the local webhook server listens on
WEBHOOK_PORT=8080

# PostgreSQL
DB_USER=botuser
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aibot_db

# Comma-separated Telegram user IDs that have admin access. Used by
# the legacy /admin* Telegram-side commands and as audit attribution
# for actions performed via the web panel.
ADMIN_USER_IDS=

# Web admin panel (Stage-8). Both must be set for the panel at
# ${WEBHOOK_BASE_URL}/admin/login to be reachable; without them the
# login form refuses every attempt with a 500.
#
#   ADMIN_PASSWORD            — the password you type at /admin/login.
#                               Plaintext (we constant-time-compare on
#                               the byte string). Pick something long.
#   ADMIN_SESSION_SECRET      — HMAC key used to sign auth cookies.
#                               At least 32 random bytes — generate
#                               with `python -c "import secrets;
#                               print(secrets.token_urlsafe(32))"`.
#                               Rotating this invalidates all live
#                               admin sessions.
#   ADMIN_SESSION_TTL_HOURS   — cookie lifetime; default 24.
#   ADMIN_COOKIE_SECURE       — set to 0 ONLY if running over plain
#                               HTTP locally; default 1 (HTTPS only).
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_HOURS=24
ADMIN_COOKIE_SECURE=1

# Set to 1 when the bot sits behind a reverse proxy (Cloudflare Tunnel,
# nginx, Caddy). The per-IP rate limiters for /nowpayments-webhook and
# /admin/login will key on the leftmost X-Forwarded-For IP instead of
# the proxy's TCP peer address. Leave UNSET on direct-internet deploys —
# an attacker can spoof X-Forwarded-For otherwise.
TRUST_PROXY_HEADERS=0

# FSM storage. Leave UNSET for local dev (in-memory storage with a
# warning) or point at a Redis instance for production so bot
# restarts don't trap users mid-checkout. The provided docker-compose
# file already wires up a redis service and sets this to
# redis://redis:6379/0, so you don't need to touch this in compose.
REDIS_URL=
