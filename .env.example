# Telegram bot token from @BotFather
BOT_TOKEN=

# OpenRouter API key (https://openrouter.ai/settings/keys)
OPENROUTER_API_KEY=

# NowPayments API key + IPN secret (Store Settings -> API keys / IPN settings)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# Public base URL where this bot's webhook is reachable (use HTTPS in production).
# The IPN endpoint will be ${WEBHOOK_BASE_URL}/nowpayments-webhook
WEBHOOK_BASE_URL=

# Port the local webhook server listens on
WEBHOOK_PORT=8080

# PostgreSQL
DB_USER=botuser
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aibot_db

# Comma-separated Telegram user IDs that have admin access
ADMIN_USER_IDS=

# FSM storage. Leave UNSET for local dev (in-memory storage with a
# warning) or point at a Redis instance for production so bot
# restarts don't trap users mid-checkout. The provided docker-compose
# file already wires up a redis service and sets this to
# redis://redis:6379/0, so you don't need to touch this in compose.
REDIS_URL=
