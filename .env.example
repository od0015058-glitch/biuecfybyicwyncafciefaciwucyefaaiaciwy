# Telegram bot token from @BotFather
BOT_TOKEN=

# OpenRouter API key (https://openrouter.ai/settings/keys)
#
# Single key (backward-compatible):
OPENROUTER_API_KEY=
#
# Multi-key load balancing (Stage-14-Step-C): set numbered vars to
# spread users across accounts. Each user sticks to one key (by
# telegram_id % N) for consistent conversation context. If any
# numbered key is present, the bare OPENROUTER_API_KEY is ignored.
# OPENROUTER_API_KEY_1=sk-or-...
# OPENROUTER_API_KEY_2=sk-or-...
# OPENROUTER_API_KEY_3=sk-or-...

# NowPayments API key + IPN secret (Store Settings -> API keys / IPN settings)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# Absolute lower bound on any wallet top-up, in USD. Every supported
# currency is additionally subject to its own per-currency NowPayments
# minimum (fetched from /v1/min-amount); the effective floor is
# max(MIN_TOPUP_USD, per_currency_min_usd). Defaults to $2. Below $2
# the gateway + internal processing overhead eats the top-up.
MIN_TOPUP_USD=2

# How often the background task refreshes the per-currency min-amount
# cache (seconds). Default 15 minutes. Minimum 60s to avoid hammering
# NowPayments. Lower = fresher numbers, higher = fewer HTTP calls.
MIN_AMOUNT_REFRESH_INTERVAL_SECONDS=900

# Public base URL where this bot's webhook is reachable (use HTTPS in production).
# The IPN endpoint will be ${WEBHOOK_BASE_URL}/nowpayments-webhook
WEBHOOK_BASE_URL=

# Port the local webhook server listens on
WEBHOOK_PORT=8080

# ---------------------------------------------------------------
# Stage-15-Step-E #3 — opt-in Telegram webhook mode
# ---------------------------------------------------------------
# Set TELEGRAM_WEBHOOK_SECRET to enable webhook delivery of
# Telegram updates instead of long-polling. The bot mounts a
# POST handler at ${TELEGRAM_WEBHOOK_BASE_URL:-${WEBHOOK_BASE_URL}}
# /telegram-webhook/<secret> on the same aiohttp app + same port
# (WEBHOOK_PORT) as the IPN webhooks. Telegram delivers updates
# only over HTTPS — set up TLS on your reverse proxy first.
#
# When unset (default), the bot continues to use long-polling
# (dp.start_polling) — backward-compatible.
#
# The secret must be 1..256 chars of [A-Za-z0-9_-]. A typo halts
# boot loudly rather than silently failing every update.
#
# Recover from a misconfigured webhook: unset this var, restart
# the bot, then call Bot.delete_webhook from a Python REPL or
# /setWebhook with an empty URL via Telegram's @BotFather console.
TELEGRAM_WEBHOOK_SECRET=

# Optional override: point Telegram at a different hostname than
# the one used for IPN callbacks (e.g. a separate subdomain or a
# port-forward). Defaults to WEBHOOK_BASE_URL when unset.
TELEGRAM_WEBHOOK_BASE_URL=

# Optional override: the URL prefix before the secret. Defaults
# to /telegram-webhook so the full path is /telegram-webhook/<secret>.
TELEGRAM_WEBHOOK_PATH_PREFIX=

# ---------------------------------------------------------------
# Stage-15-Step-E #3 follow-up — webhook hardening (all optional)
# ---------------------------------------------------------------
# Opt-in IP allowlist for the Telegram webhook receiver. Defence
# in depth on top of the secret + secret-token-header check —
# rejects any POST to /telegram-webhook/<secret> from outside
# the configured ranges *before* the body is parsed.
#
#   * Unset (default): no IP check, the secret + header are the
#     only gates. Backward-compatible.
#   * "default":       Telegram's documented delivery ranges
#                      (149.154.160.0/20, 91.108.4.0/22).
#   * Comma-separated CIDRs: e.g. "10.0.0.0/8,192.168.1.5" for
#     a private deploy fronted by a reverse proxy on a known IP.
#
# Trusts only request.remote (NOT X-Forwarded-For) so a public-
# facing reverse proxy that's tricked into spoofing the header
# can't bypass the allowlist.
TELEGRAM_WEBHOOK_IP_ALLOWLIST=

# Retry tunables for the boot-time set_webhook call. Defaults
# give 1 + 2 + 4 = 7s worst-case wait across three attempts
# before escalating — long enough to ride out a Telegram blip,
# short enough that a real outage still surfaces in seconds.
# TelegramBadRequest (HTTP 400 — bad URL, invalid secret_token
# shape) is NOT retried; that's a deploy-side typo.
TELEGRAM_WEBHOOK_REGISTER_MAX_ATTEMPTS=
TELEGRAM_WEBHOOK_REGISTER_BASE_DELAY_SECONDS=

# PostgreSQL
DB_USER=botuser
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aibot_db

# Comma-separated Telegram user IDs that have admin access. Used by
# the legacy /admin* Telegram-side commands and as audit attribution
# for actions performed via the web panel.
ADMIN_USER_IDS=

# Web admin panel (Stage-8). Both must be set for the panel at
# ${WEBHOOK_BASE_URL}/admin/login to be reachable; without them the
# login form refuses every attempt with a 500.
#
#   ADMIN_PASSWORD            — the password you type at /admin/login.
#                               Plaintext (we constant-time-compare on
#                               the byte string). Pick something long.
#                               Stage-15-Step-E #10b row 25: a panel
#                               operator can ALSO rotate the password
#                               from /admin/profile, which writes a
#                               scrypt hash to system_settings under
#                               key ADMIN_PASSWORD_HASH. When that DB
#                               row is set the env value becomes the
#                               back-compat fallback for unrotated
#                               deploys; it is otherwise ignored. To
#                               un-rotate (e.g. recovering from a
#                               forgotten new password), DELETE the
#                               system_settings row and the env value
#                               takes effect again on the next login.
#   ADMIN_SESSION_SECRET      — HMAC key used to sign auth cookies.
#                               At least 32 random bytes — generate
#                               with `python -c "import secrets;
#                               print(secrets.token_urlsafe(32))"`.
#                               Rotating this invalidates all live
#                               admin sessions.
#   ADMIN_SESSION_TTL_HOURS   — cookie lifetime; default 24.
#   ADMIN_COOKIE_SECURE       — set to 0 ONLY if running over plain
#                               HTTP locally; default 1 (HTTPS only).
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_HOURS=24
ADMIN_COOKIE_SECURE=1

# Optional second factor on the admin login (Stage-9-Step-3). When
# set to a base32 TOTP secret, /admin/login requires a 6-digit code
# from an authenticator app (Google Authenticator, Authy, 1Password,
# Bitwarden) IN ADDITION to the password. Leave UNSET to keep the
# password-only login flow.
#
# Provisioning: log in, visit ${WEBHOOK_BASE_URL}/admin/enroll_2fa,
# scan the QR with your authenticator, paste the displayed base32
# secret into ADMIN_2FA_SECRET, then restart the bot. The page also
# generates a fresh suggested secret you can use for first-time
# setup before any value is configured.
#
# ADMIN_2FA_ISSUER labels the entry inside the authenticator app
# ("Meowassist Admin" by default). Picking a project-specific
# issuer makes it easier to spot in a long list of TOTP entries.
ADMIN_2FA_SECRET=
ADMIN_2FA_ISSUER=Meowassist Admin

# Stage-15-Step-E #10b row 26: how long (in seconds) a suggested
# TOTP secret stays valid on /admin/enroll_2fa before the page auto-
# reloads with a fresh one. Default 300 (5 min). Range [30, 3600].
# Editable from the /admin/enroll_2fa page itself (DB-backed override).
# ADMIN_2FA_ENROLLMENT_TIMEOUT=300

# Set to 1 when the bot sits behind a reverse proxy (Cloudflare Tunnel,
# nginx, Caddy). The per-IP rate limiters for /nowpayments-webhook and
# /admin/login will key on the leftmost X-Forwarded-For IP instead of
# the proxy's TCP peer address. Leave UNSET on direct-internet deploys —
# an attacker can spoof X-Forwarded-For otherwise.
TRUST_PROXY_HEADERS=0

# FSM storage. Leave UNSET for local dev (in-memory storage with a
# warning) or point at a Redis instance for production so bot
# restarts don't trap users mid-checkout. The provided docker-compose
# file already wires up a redis service and sets this to
# redis://redis:6379/0, so you don't need to touch this in compose.
REDIS_URL=

# Conversation memory caps (Stage-15-Step-E #10b row 8). Both are
# overridable via the ``/admin/memory-config`` web panel (DB-backed,
# no redeploy needed). Env values are the second-priority fallback
# after a DB override; compile-time defaults are last.
#   MEMORY_CONTEXT_LIMIT     — max recent messages fed as context on
#                              each chat turn. Default 30. Range [1, 500].
#   MEMORY_CONTENT_MAX_CHARS — per-message content cap before persist.
#                              Default 8000. Range [100, 100000].
#MEMORY_CONTEXT_LIMIT=30
#MEMORY_CONTENT_MAX_CHARS=8000

# Background reaper for stuck PENDING transactions (Stage-9-Step-5).
# All three are optional; leaving them unset uses the safe defaults
# below. The reaper runs in-process — no separate cron / worker.
#   PENDING_EXPIRATION_INTERVAL_MIN — how often the reaper wakes,
#                                     in minutes. Default 15.
#   PENDING_EXPIRATION_HOURS        — minimum age (created_at < NOW()
#                                     - this) for a PENDING row to be
#                                     flipped to EXPIRED. Default 24.
#                                     Floored at 1 hour to prevent a
#                                     deploy-time typo from EXPIRing
#                                     every PENDING row in the table.
#   PENDING_EXPIRATION_BATCH        — max rows touched per tick.
#                                     Default 1000. The reaper drains
#                                     larger backlogs across multiple
#                                     ticks so a single UPDATE can't
#                                     blow the asyncpg pool.
PENDING_EXPIRATION_INTERVAL_MIN=15
PENDING_EXPIRATION_HOURS=24
PENDING_EXPIRATION_BATCH=1000

# Background loop that proactively DMs admins about stuck PENDING
# transactions (Stage-12-Step-B). Complements the reaper — the
# reaper *closes* rows that crossed the 24 h terminal threshold;
# this loop *notifies* about rows that crossed a much earlier alert
# threshold so the operator can intervene before the reaper does.
# All three are optional with safe defaults.
#   PENDING_ALERT_INTERVAL_MIN     — how often the alert loop wakes,
#                                    in minutes. Default 30. Floored
#                                    at 1 min (mostly for tests).
#   PENDING_ALERT_THRESHOLD_HOURS  — a PENDING row's age (NOW() -
#                                    created_at) must exceed this for
#                                    the loop to alert on it. Default
#                                    2. Floored at 1 h.
#   PENDING_ALERT_LIMIT            — DB-side row cap per pass.
#                                    Default 500. The DM body itself
#                                    truncates well before this — this
#                                    is just a transfer-size belt.
PENDING_ALERT_INTERVAL_MIN=30
PENDING_ALERT_THRESHOLD_HOURS=2
PENDING_ALERT_LIMIT=500

# Audit log retention reaper (Stage-15-Step-E #10b row 20).
# Prunes admin_audit_log rows older than AUDIT_RETENTION_DAYS.
# AUDIT_RETENTION_DAYS is overridable via /admin/audit (DB-backed,
# no redeploy needed). Env value is the second-priority fallback
# after a DB override; compile-time default (90 days) is last.
#   AUDIT_RETENTION_DAYS           — retention window in days.
#                                    Default 90. Range [7, 3650].
#   AUDIT_RETENTION_INTERVAL_HOURS — how often the reaper wakes.
#                                    Default 24 (once per day).
#   AUDIT_RETENTION_BATCH          — max rows deleted per SQL
#                                    statement. Default 5000.
#AUDIT_RETENTION_DAYS=90
#AUDIT_RETENTION_INTERVAL_HOURS=24
#AUDIT_RETENTION_BATCH=5000

# Refund presets (Stage-15-Step-E #10b row 28).
# Operator-curated list of common refund reasons surfaced as a
# dropdown above the free-text reason field on the
# /admin/transactions refund form. Operators can edit the list
# from /admin/refund-presets at runtime; that DB-backed override
# beats this env value (resolution order: DB override → env →
# compile-time default of "Duplicate payment", "User-requested
# cancellation", "Stuck invoice — never credited",
# "Fraud / chargeback", "Bot or platform error").
# Format: newline- and/or pipe-separated entries. Each entry is
# stripped, NUL-stripped, case-insensitive-deduped, and capped
# at 40 chars; the list is capped at 5 entries to keep the
# JSON payload under the 255-char system_settings column limit.
# Examples (uncomment + edit one form):
#REFUND_PRESETS="Duplicate payment|User cancellation|Stuck invoice|Bot error"
#REFUND_PRESETS="Duplicate payment
#User cancellation
#Stuck invoice"

# I18N edit lock (Stage-15-Step-E #10b row 22).
# When truthy, the /admin/strings save / revert handlers refuse
# every write with a flash error and an audit row. Useful during
# a rolling deploy or messages.po round-trip when you don't want
# a translator to land a half-finished edit. Operators can flip
# the lock at runtime from the /admin/strings banner — that
# DB-backed override beats this env value (resolution order:
# DB override → env → default `false`).
# Truthy tokens (case-insensitive, whitespace-stripped):
#   1, true, t, yes, y, on, lock, locked
# Falsy tokens (treated as explicitly unlocked):
#   0, false, f, no, n, off, unlock, unlocked
# Anything else is ignored (falls through to the default `false`).
#I18N_LOCK=0

# Bot-health classifier + proactive alert loop (Stage-15-Step-F).
# Drives the /admin/control panel's traffic-light tile, the
# meowassist_bot_status_score Prometheus gauge, AND the proactive
# Telegram-DM loop in bot_health_alert.py that pages admins on
# transitions to DEGRADED / UNDER_ATTACK / DOWN. All optional with
# safe defaults — these are the "operator can tune per deploy"
# knobs.
#
#   BOT_HEALTH_BUSY_INFLIGHT             — in-flight chat slot count
#                                          that flips the tile to
#                                          BUSY. Default 50.
#   BOT_HEALTH_LOOP_STALE_SECONDS        — seconds since last
#                                          successful tick that flips
#                                          a background loop to stale
#                                          (→ DEGRADED). Default 1800
#                                          (30 min). NB this is a
#                                          *fallback* for unknown loop
#                                          names — every registered
#                                          loop has a per-loop
#                                          threshold derived from its
#                                          published cadence
#                                          (bot_health.LOOP_CADENCES,
#                                          stale = 2 × cadence + 60s).
#                                          Override per-loop via
#                                          BOT_HEALTH_LOOP_STALE_<NAME>_SECONDS
#                                          (e.g.
#                                          BOT_HEALTH_LOOP_STALE_FX_REFRESH_SECONDS).
#   BOT_HEALTH_IPN_DROP_ATTACK_THRESHOLD — IPN deliveries dropped in
#                                          the recent rate-window
#                                          that flips the tile to
#                                          UNDER_ATTACK. Default 100.
#                                          Maintained by
#                                          bot_health_alert.py as a
#                                          delta-since-last-tick.
#   BOT_HEALTH_LOGIN_THROTTLE_ATTACK_KEYS — distinct IPs holding a
#                                           login-throttle bucket
#                                           that flips to
#                                           UNDER_ATTACK. Default 25.
#   BOT_HEALTH_ALERT_INTERVAL_SECONDS    — how often the proactive
#                                          DM loop wakes, in seconds.
#                                          Default 60. Floored at 1.
#                                          A shorter interval makes
#                                          the rate-windowed
#                                          UNDER_ATTACK detection
#                                          tighter (a 100-drop burst
#                                          must fit in one window to
#                                          trip).
BOT_HEALTH_BUSY_INFLIGHT=50
BOT_HEALTH_LOOP_STALE_SECONDS=1800
BOT_HEALTH_IPN_DROP_ATTACK_THRESHOLD=100
BOT_HEALTH_LOGIN_THROTTLE_ATTACK_KEYS=25
BOT_HEALTH_ALERT_INTERVAL_SECONDS=60

# User-facing wallet receipts (Stage-12-Step-C). Per-page size for
# the "🧾 Recent top-ups" wallet sub-screen. Capped at 20 to stay
# under Telegram's 4 KB message limit even with the longest
# rendered TetraPay row (USD + locked Toman line).
RECEIPTS_PAGE_SIZE=5

# Background loop that diffs the live OpenRouter catalog against the
# ``seen_models`` watermark table and DMs every admin in
# ADMIN_USER_IDS when a genuinely new model appears (Stage-10-Step-C).
# First deploy silently bootstraps the seen-set (no DMs) so admins
# aren't flooded with the full ~200-model catalog on day 1.
#
#   DISCOVERY_INTERVAL_SECONDS       — how often the loop runs, in
#                                      seconds. Default 21 600 (6h).
#                                      Overridable via /admin/models-config
#                                      (DB-backed, no redeploy needed).
#                                      Range [60, 604 800].
#   DISCOVERY_MAX_MODELS_PER_DM      — hard cap on models per DM so we
#                                      don't bust Telegram's
#                                      4 096-char message limit when
#                                      a provider ships a big drop.
#                                      Default 10. Overflow count is
#                                      appended to the DM footer.
#   ADMIN_NOTIFY_DISCOVERY_PROVIDERS — comma-separated provider slugs
#                                      to notify about. Default:
#                                      "openai,anthropic,google,
#                                      x-ai,deepseek" — the same five
#                                      the model picker surfaces as
#                                      top-level buttons. Set to "*"
#                                      to get DMs for every provider
#                                      (noisy; meta + qwen + mistral
#                                      can ship 50+ variants per drop).
DISCOVERY_INTERVAL_SECONDS=21600
DISCOVERY_MAX_MODELS_PER_DM=10
ADMIN_NOTIFY_DISCOVERY_PROVIDERS=openai,anthropic,google,x-ai,deepseek

# Stage-10-Step-D: price-delta alerts piggyback on the same discovery
# loop. On each pass we force-refresh the live catalog (bypassing the
# 24h in-memory TTL) and diff current prices against the persisted
# ``model_prices`` table. A model whose per-1M input OR output price
# moved by more than this threshold (in percent) triggers a separate
# admin DM. 20% is a good default — catches silent upstream bumps
# without firing on the ≤5% re-denominations OpenRouter sometimes
# emits when switching tokens-per-dollar units.
PRICE_ALERT_THRESHOLD_PERCENT=20.0

# Stage-11-Step-A: live USD→Toman exchange rate ticker. The wallet
# balance is denominated in USD (invariant) — Toman is display /
# input currency for Iranian users. The ``fx_rates`` background
# refresher polls this rate on a 10-minute cadence, persists it to
# ``fx_rates_snapshot``, and DMs admins on rate moves above
# FX_RATE_ALERT_THRESHOLD_PERCENT between successive refreshes.
#
# Source options (``FX_RATE_SOURCE``):
#   nobitex          — default. Pulls USDT/IRR from api.nobitex.ir
#                      (free, no auth, heavy daily volume; USDT
#                      tracks USD within a fraction of a percent).
#                      Rial values ÷10 for tomans.
#   bonbast          — parallel-market scrape (no official API —
#                      point FX_RATE_ENDPOINT at a JSON mirror).
#   custom_json_path — generic: fetches FX_RATE_ENDPOINT as JSON
#                      and reads the value at FX_RATE_JSON_PATH
#                      (dotted: e.g. "data.latest_price").
#   custom_static    — no HTTP, returns FX_RATE_STATIC_VALUE.
#                      Tests / staging only.
#
# Stage-15-Step-E #10b row 24: FX_REFRESH_INTERVAL_SECONDS is also
# tunable from /admin/wallet-config without a redeploy. The DB
# override (system_settings.FX_REFRESH_INTERVAL_SECONDS) wins over
# the env var when both are set; emptying the editor field clears
# the override and falls back through env -> compile-time default.
# Range: 60s (1 min) – 86400s (1 day).
FX_REFRESH_INTERVAL_SECONDS=600
FX_RATE_ALERT_THRESHOLD_PERCENT=10.0
FX_RATE_SOURCE=nobitex
FX_RATE_ENDPOINT=https://api.nobitex.ir/market/stats?srcCurrency=usdt&dstCurrency=rls
# FX_RATE_JSON_PATH=price          # only used when FX_RATE_SOURCE=custom_json_path
# FX_RATE_STATIC_VALUE=95000.0     # only used when FX_RATE_SOURCE=custom_static

# TetraPay (Iranian Rial card / Shaparak gateway). Stage-11-Step-C.
# Settlement callback is delivered to ${WEBHOOK_BASE_URL}/tetrapay-webhook.
# The bot must be configured in the TetraPay merchant panel with that
# exact URL or callbacks will be rejected.
#
# TETRAPAY_API_KEY: merchant API key from the TetraPay panel. Without
#   it, /api/create_order calls are refused locally (no HTTP issued).
# TETRAPAY_API_BASE: optional override of https://tetra98.com. Useful
#   for staging or if TetraPay rotates their API host.
# TETRAPAY_REQUEST_TIMEOUT_SECONDS: optional float, default 10. Same
#   shape as the NowPayments timeout; positive values only.
TETRAPAY_API_KEY=
# TETRAPAY_API_BASE=https://tetra98.com
# TETRAPAY_REQUEST_TIMEOUT_SECONDS=10

# Zarinpal (Iranian Rial card / Shaparak gateway). Stage-15-Step-E #8.
# Alternative to TetraPay for merchants who prefer Zarinpal's larger
# OEM coverage and v4 API ergonomics. Unlike TetraPay (POST webhook),
# Zarinpal redirects the user's BROWSER back to
# ${WEBHOOK_BASE_URL}/zarinpal-callback with ``?Authority=…&Status=OK|NOK``
# query parameters — there is no separate server-to-server webhook.
# The bot must be configured in the Zarinpal merchant panel with that
# exact URL or callbacks will be silently dropped.
#
# ZARINPAL_MERCHANT_ID: 36-char merchant id from the Zarinpal panel
#   (looks like a GUID). Without it, /v4/payment/request.json calls
#   are refused locally (no HTTP issued).
# ZARINPAL_API_BASE: optional override of
#   https://payment.zarinpal.com/pg. Useful for staging
#   (https://sandbox.zarinpal.com/pg) or for swapping endpoints if
#   Zarinpal rotates their API host. The browser-redirect StartPay
#   URL is derived from this base, so a sandbox override redirects
#   the user to the sandbox payment screen too.
# ZARINPAL_REQUEST_TIMEOUT_SECONDS: optional float, default 10. Same
#   shape as the TetraPay timeout; positive values only.
ZARINPAL_MERCHANT_ID=
# ZARINPAL_API_BASE=https://payment.zarinpal.com/pg
# ZARINPAL_REQUEST_TIMEOUT_SECONDS=10

# Stage-13-Step-A: required-channel subscription gate. When set, every
# non-admin user must be a member of this channel before any handler
# (including /start) runs — they get a "Please join @channel" screen
# with a Join button + an "✅ I've joined" re-check button until
# Telegram's Bot API confirms membership. Leave UNSET to keep the
# bot fully open (back-compat default).
#
# REQUIRED_CHANNEL accepts either a public ``@username`` (e.g.
# ``@MeowAssist_Channel``) or a numeric ``-100…`` chat id for a
# private channel / supergroup. The bot must be added as an
# administrator of the channel — Telegram only lets bots query
# membership for chats they administer. If the bot isn't admin yet,
# the gate fails OPEN with a logged WARNING (so an operator
# bootstrapping the channel doesn't lock every user out).
#
# REQUIRED_CHANNEL_INVITE_LINK overrides the synthesised join URL.
# Leave unset for public ``@handle`` channels — we synthesise
# ``https://t.me/<handle>`` automatically. SET this to a join-request
# / private-invite URL (``https://t.me/+abcdefINVITE``) when
# REQUIRED_CHANNEL is a numeric private-channel id, otherwise the
# Join button is omitted (the user can still tap "I've joined" but
# the bot won't deep-link them to anywhere).
#
# Admins listed in ADMIN_USER_IDS always bypass the gate so the
# operator can never lock themselves out of their own bot.
REQUIRED_CHANNEL=
# REQUIRED_CHANNEL_INVITE_LINK=https://t.me/+abcdefINVITE

# Stage-13-Step-C — referral codes (user-to-user invites that credit
# both wallets on the invitee's first paid top-up). Three knobs:
#
# BOT_USERNAME — the bot's @handle without the leading @ (e.g.
# ``Meowassist_Ai_bot``). Used to synthesise the share deep-link
# ``https://t.me/<handle>?start=ref_<code>`` rendered on the
# /wallet → "Invite a friend" screen. Leave unset and the screen
# falls back to a copy-paste-only flow (the bare code + a
# /start ref_<code> instruction); the feature still works, just
# without a one-tap link.
#
# REFERRAL_BONUS_PERCENT — percentage of the invitee's first paid
# top-up credited to BOTH wallets (referrer + invitee). Defaults to
# 10 (i.e. 10%). Capped at REFERRAL_BONUS_MAX_USD per side. Non-finite
# / non-positive values fall back to the default with a logged WARNING.
#
# REFERRAL_BONUS_MAX_USD — per-side cap on the bonus. Defaults to $5.
# So a $20 first-top-up triggers 10% × $20 = $2 to each side; a $100
# first-top-up triggers $5 (the cap), not $10.
BOT_USERNAME=
REFERRAL_BONUS_PERCENT=10
REFERRAL_BONUS_MAX_USD=5

# Stage-15-Step-A — Prometheus /metrics endpoint.
#
# When set, the aiohttp server publishes a `GET /metrics` route in
# Prometheus text-exposition format alongside the existing IPN /
# admin routes. Output includes per-loop heartbeat epochs, IPN drop
# counters, in-flight chat-slot count, disabled-models / gateways
# counts, and the OpenRouter-key pool size — see metrics.render_metrics.
#
# METRICS_IP_ALLOWLIST — comma-separated list of IPs / CIDRs allowed
# to scrape the endpoint. Default `127.0.0.1,::1` (localhost only),
# tuned for a sidecar Prometheus / VictoriaMetrics pod that scrapes
# 127.0.0.1:8080/metrics. Override for split-host setups, e.g.
# `10.0.0.0/8,192.168.0.0/16`. An empty value locks every request
# out (fail-closed) — comment the line entirely to fall back to the
# default rather than to "lock everyone out".
METRICS_IP_ALLOWLIST=127.0.0.1,::1

# Stage-16 row 17: real /health (and /healthz) endpoint that probes
# Postgres + Redis + OpenRouter + every registered background loop.
# Mounted unconditionally on the same aiohttp app as /admin/* and
# /metrics. Public-safe — body never echoes secrets, hostnames, or
# env-var values. Hit it from UptimeRobot / BetterStack / Pingdom
# every 60s for real outage paging.
#
# HEALTH_CACHE_SECONDS — in-process snapshot cache TTL. A polling
# monitor that hammers /health more often than this serves the cached
# result (no live DB / Redis / OpenRouter probes), so a flood can't
# proxy-storm dependencies. Default 5s — long enough to absorb a
# legitimate flood, short enough that a real outage shows up within
# one normal poll cycle.
HEALTH_CACHE_SECONDS=5

# HEALTH_PROBE_TIMEOUT_SECONDS — per-probe timeout. Postgres SELECT 1,
# Redis PING, and the OpenRouter models GET each cap at this. Failure
# to complete inside the window reports the dependency as down /
# degraded. Default 3s — well under the 30s default monitor request
# deadline so a hung dep never causes the whole endpoint to time out.
HEALTH_PROBE_TIMEOUT_SECONDS=3

# Stage-15-Step-E #6 — Telethon-driven integration tests.
#
# These four vars gate the opt-in suite under ``tests/integration/``.
# Leave them ALL unset to skip the suite cleanly (the default in CI).
# Set them ONLY in a local dev shell to drive a live test bot.
#
# Setup walkthrough lives in ``tests/integration/conftest.py``. Quick
# summary:
#   1. Register a Telegram developer at https://my.telegram.org →
#      "API development tools" to get TG_API_ID + TG_API_HASH.
#   2. Generate TG_TEST_SESSION_STRING with the throwaway script in
#      conftest.py (one-time login flow). Treat the printed string
#      like a password — anyone holding it can impersonate the user.
#   3. Spin up a SEPARATE test bot (NOT the production bot) — a
#      flaky test must not be able to credit / refund / broadcast
#      to real users. Set TG_TEST_BOT_USERNAME to its @username
#      (without the @).
#
# TG_API_ID — integer, per Telegram developer account.
# TG_API_HASH — 32-char hex string, per Telegram developer account.
# TG_TEST_SESSION_STRING — Telethon ``StringSession.save()`` output.
# TG_TEST_BOT_USERNAME — bot @username without the leading @.
# TG_TEST_TIMEOUT_SECONDS — optional, default 15. How long to wait
#   for a bot reply before failing a test. Bump if your test bot
#   shares a slow OpenRouter key.
# TG_TEST_SETTLE_SECONDS — optional, default 0.5. Pause between the
#   send and the start of the reply-poll. Telegram's long-poll has
#   its own latency floor; this avoids hammering iter_messages
#   before the bot has had a chance to write its reply.
# TG_API_ID=
# TG_API_HASH=
# TG_TEST_SESSION_STRING=
# TG_TEST_BOT_USERNAME=
# TG_TEST_TIMEOUT_SECONDS=15
# TG_TEST_SETTLE_SECONDS=0.5

# ── Stage-16 row 20: abuse / spam detection ────────────────────────
# Three independent layers, each toggle-able. The classifier
# short-circuits in process_chat BEFORE consume_chat_token so an
# oversized / probe-shaped prompt doesn't burn a rate-limit slot a
# legitimate user could otherwise use. Same ai_local_rate_limited
# reply for every non-OK classification so an attacker can't probe
# which rule fired.

# ABUSE_DETECTION_ENABLED — master switch (default true). Setting
#   this to false disables ALL three layers; use the per-layer
#   switches below if you only want to disable one.
# ABUSE_DETECTION_ENABLED=true

# ABUSE_PATTERNS_ENABLED — regex layer only (default true). Disable
#   if you're hitting false-positives on legitimate code-block
#   pastes; the length cap and spike tracker stay active.
# ABUSE_PATTERNS_ENABLED=true

# ABUSE_SPEND_SPIKE_ENABLED — spike tracker only (default true).
# ABUSE_SPEND_SPIKE_ENABLED=true

# ABUSE_MAX_PROMPT_CHARS — hard upper bound on user prompts.
#   Default 50 000. Values below the floor of 1 000 are clamped
#   so an env typo can't silently disable the limit; use
#   ABUSE_DETECTION_ENABLED=false to actually disable.
# ABUSE_MAX_PROMPT_CHARS=50000

# ABUSE_SPEND_SPIKE_WINDOW_SECONDS — sliding window length for the
#   spike tracker. Default 600 (10 min). Floor 60.
# ABUSE_SPEND_SPIKE_WINDOW_SECONDS=600

# ABUSE_SPEND_SPIKE_THRESHOLD_USD — alert trigger. Default 5.0.
#   When a user's rolling-window total crosses this, every admin
#   gets one DM with the breach detail (rolling total, last call
#   cost, window). Idempotent — a second prompt above the threshold
#   doesn't re-DM until the window total drops back below the
#   threshold.
# ABUSE_SPEND_SPIKE_THRESHOLD_USD=5.0
