# Telegram bot token from @BotFather
BOT_TOKEN=

# OpenRouter API key (https://openrouter.ai/settings/keys)
#
# Single key (backward-compatible):
OPENROUTER_API_KEY=
#
# Multi-key load balancing (Stage-14-Step-C): set numbered vars to
# spread users across accounts. Each user sticks to one key (by
# telegram_id % N) for consistent conversation context. If any
# numbered key is present, the bare OPENROUTER_API_KEY is ignored.
# OPENROUTER_API_KEY_1=sk-or-...
# OPENROUTER_API_KEY_2=sk-or-...
# OPENROUTER_API_KEY_3=sk-or-...

# NowPayments API key + IPN secret (Store Settings -> API keys / IPN settings)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# Absolute lower bound on any wallet top-up, in USD. Every supported
# currency is additionally subject to its own per-currency NowPayments
# minimum (fetched from /v1/min-amount); the effective floor is
# max(MIN_TOPUP_USD, per_currency_min_usd). Defaults to $2. Below $2
# the gateway + internal processing overhead eats the top-up.
MIN_TOPUP_USD=2

# How often the background task refreshes the per-currency min-amount
# cache (seconds). Default 15 minutes. Minimum 60s to avoid hammering
# NowPayments. Lower = fresher numbers, higher = fewer HTTP calls.
MIN_AMOUNT_REFRESH_INTERVAL_SECONDS=900

# Public base URL where this bot's webhook is reachable (use HTTPS in production).
# The IPN endpoint will be ${WEBHOOK_BASE_URL}/nowpayments-webhook
WEBHOOK_BASE_URL=

# Port the local webhook server listens on
WEBHOOK_PORT=8080

# PostgreSQL
DB_USER=botuser
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aibot_db

# Comma-separated Telegram user IDs that have admin access. Used by
# the legacy /admin* Telegram-side commands and as audit attribution
# for actions performed via the web panel.
ADMIN_USER_IDS=

# Web admin panel (Stage-8). Both must be set for the panel at
# ${WEBHOOK_BASE_URL}/admin/login to be reachable; without them the
# login form refuses every attempt with a 500.
#
#   ADMIN_PASSWORD            — the password you type at /admin/login.
#                               Plaintext (we constant-time-compare on
#                               the byte string). Pick something long.
#   ADMIN_SESSION_SECRET      — HMAC key used to sign auth cookies.
#                               At least 32 random bytes — generate
#                               with `python -c "import secrets;
#                               print(secrets.token_urlsafe(32))"`.
#                               Rotating this invalidates all live
#                               admin sessions.
#   ADMIN_SESSION_TTL_HOURS   — cookie lifetime; default 24.
#   ADMIN_COOKIE_SECURE       — set to 0 ONLY if running over plain
#                               HTTP locally; default 1 (HTTPS only).
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_HOURS=24
ADMIN_COOKIE_SECURE=1

# Optional second factor on the admin login (Stage-9-Step-3). When
# set to a base32 TOTP secret, /admin/login requires a 6-digit code
# from an authenticator app (Google Authenticator, Authy, 1Password,
# Bitwarden) IN ADDITION to the password. Leave UNSET to keep the
# password-only login flow.
#
# Provisioning: log in, visit ${WEBHOOK_BASE_URL}/admin/enroll_2fa,
# scan the QR with your authenticator, paste the displayed base32
# secret into ADMIN_2FA_SECRET, then restart the bot. The page also
# generates a fresh suggested secret you can use for first-time
# setup before any value is configured.
#
# ADMIN_2FA_ISSUER labels the entry inside the authenticator app
# ("Meowassist Admin" by default). Picking a project-specific
# issuer makes it easier to spot in a long list of TOTP entries.
ADMIN_2FA_SECRET=
ADMIN_2FA_ISSUER=Meowassist Admin

# Set to 1 when the bot sits behind a reverse proxy (Cloudflare Tunnel,
# nginx, Caddy). The per-IP rate limiters for /nowpayments-webhook and
# /admin/login will key on the leftmost X-Forwarded-For IP instead of
# the proxy's TCP peer address. Leave UNSET on direct-internet deploys —
# an attacker can spoof X-Forwarded-For otherwise.
TRUST_PROXY_HEADERS=0

# FSM storage. Leave UNSET for local dev (in-memory storage with a
# warning) or point at a Redis instance for production so bot
# restarts don't trap users mid-checkout. The provided docker-compose
# file already wires up a redis service and sets this to
# redis://redis:6379/0, so you don't need to touch this in compose.
REDIS_URL=

# Background reaper for stuck PENDING transactions (Stage-9-Step-5).
# All three are optional; leaving them unset uses the safe defaults
# below. The reaper runs in-process — no separate cron / worker.
#   PENDING_EXPIRATION_INTERVAL_MIN — how often the reaper wakes,
#                                     in minutes. Default 15.
#   PENDING_EXPIRATION_HOURS        — minimum age (created_at < NOW()
#                                     - this) for a PENDING row to be
#                                     flipped to EXPIRED. Default 24.
#                                     Floored at 1 hour to prevent a
#                                     deploy-time typo from EXPIRing
#                                     every PENDING row in the table.
#   PENDING_EXPIRATION_BATCH        — max rows touched per tick.
#                                     Default 1000. The reaper drains
#                                     larger backlogs across multiple
#                                     ticks so a single UPDATE can't
#                                     blow the asyncpg pool.
PENDING_EXPIRATION_INTERVAL_MIN=15
PENDING_EXPIRATION_HOURS=24
PENDING_EXPIRATION_BATCH=1000

# Background loop that proactively DMs admins about stuck PENDING
# transactions (Stage-12-Step-B). Complements the reaper — the
# reaper *closes* rows that crossed the 24 h terminal threshold;
# this loop *notifies* about rows that crossed a much earlier alert
# threshold so the operator can intervene before the reaper does.
# All three are optional with safe defaults.
#   PENDING_ALERT_INTERVAL_MIN     — how often the alert loop wakes,
#                                    in minutes. Default 30. Floored
#                                    at 1 min (mostly for tests).
#   PENDING_ALERT_THRESHOLD_HOURS  — a PENDING row's age (NOW() -
#                                    created_at) must exceed this for
#                                    the loop to alert on it. Default
#                                    2. Floored at 1 h.
#   PENDING_ALERT_LIMIT            — DB-side row cap per pass.
#                                    Default 500. The DM body itself
#                                    truncates well before this — this
#                                    is just a transfer-size belt.
PENDING_ALERT_INTERVAL_MIN=30
PENDING_ALERT_THRESHOLD_HOURS=2
PENDING_ALERT_LIMIT=500

# User-facing wallet receipts (Stage-12-Step-C). Per-page size for
# the "🧾 Recent top-ups" wallet sub-screen. Capped at 20 to stay
# under Telegram's 4 KB message limit even with the longest
# rendered TetraPay row (USD + locked Toman line).
RECEIPTS_PAGE_SIZE=5

# Background loop that diffs the live OpenRouter catalog against the
# ``seen_models`` watermark table and DMs every admin in
# ADMIN_USER_IDS when a genuinely new model appears (Stage-10-Step-C).
# First deploy silently bootstraps the seen-set (no DMs) so admins
# aren't flooded with the full ~200-model catalog on day 1.
#
#   DISCOVERY_INTERVAL_SECONDS       — how often the loop runs, in
#                                      seconds. Default 21 600 (6h).
#   DISCOVERY_MAX_MODELS_PER_DM      — hard cap on models per DM so we
#                                      don't bust Telegram's
#                                      4 096-char message limit when
#                                      a provider ships a big drop.
#                                      Default 10. Overflow count is
#                                      appended to the DM footer.
#   ADMIN_NOTIFY_DISCOVERY_PROVIDERS — comma-separated provider slugs
#                                      to notify about. Default:
#                                      "openai,anthropic,google,
#                                      x-ai,deepseek" — the same five
#                                      the model picker surfaces as
#                                      top-level buttons. Set to "*"
#                                      to get DMs for every provider
#                                      (noisy; meta + qwen + mistral
#                                      can ship 50+ variants per drop).
DISCOVERY_INTERVAL_SECONDS=21600
DISCOVERY_MAX_MODELS_PER_DM=10
ADMIN_NOTIFY_DISCOVERY_PROVIDERS=openai,anthropic,google,x-ai,deepseek

# Stage-10-Step-D: price-delta alerts piggyback on the same discovery
# loop. On each pass we force-refresh the live catalog (bypassing the
# 24h in-memory TTL) and diff current prices against the persisted
# ``model_prices`` table. A model whose per-1M input OR output price
# moved by more than this threshold (in percent) triggers a separate
# admin DM. 20% is a good default — catches silent upstream bumps
# without firing on the ≤5% re-denominations OpenRouter sometimes
# emits when switching tokens-per-dollar units.
PRICE_ALERT_THRESHOLD_PERCENT=20.0

# Stage-11-Step-A: live USD→Toman exchange rate ticker. The wallet
# balance is denominated in USD (invariant) — Toman is display /
# input currency for Iranian users. The ``fx_rates`` background
# refresher polls this rate on a 10-minute cadence, persists it to
# ``fx_rates_snapshot``, and DMs admins on rate moves above
# FX_RATE_ALERT_THRESHOLD_PERCENT between successive refreshes.
#
# Source options (``FX_RATE_SOURCE``):
#   nobitex          — default. Pulls USDT/IRR from api.nobitex.ir
#                      (free, no auth, heavy daily volume; USDT
#                      tracks USD within a fraction of a percent).
#                      Rial values ÷10 for tomans.
#   bonbast          — parallel-market scrape (no official API —
#                      point FX_RATE_ENDPOINT at a JSON mirror).
#   custom_json_path — generic: fetches FX_RATE_ENDPOINT as JSON
#                      and reads the value at FX_RATE_JSON_PATH
#                      (dotted: e.g. "data.latest_price").
#   custom_static    — no HTTP, returns FX_RATE_STATIC_VALUE.
#                      Tests / staging only.
FX_REFRESH_INTERVAL_SECONDS=600
FX_RATE_ALERT_THRESHOLD_PERCENT=10.0
FX_RATE_SOURCE=nobitex
FX_RATE_ENDPOINT=https://api.nobitex.ir/market/stats?srcCurrency=usdt&dstCurrency=rls
# FX_RATE_JSON_PATH=price          # only used when FX_RATE_SOURCE=custom_json_path
# FX_RATE_STATIC_VALUE=95000.0     # only used when FX_RATE_SOURCE=custom_static

# TetraPay (Iranian Rial card / Shaparak gateway). Stage-11-Step-C.
# Settlement callback is delivered to ${WEBHOOK_BASE_URL}/tetrapay-webhook.
# The bot must be configured in the TetraPay merchant panel with that
# exact URL or callbacks will be rejected.
#
# TETRAPAY_API_KEY: merchant API key from the TetraPay panel. Without
#   it, /api/create_order calls are refused locally (no HTTP issued).
# TETRAPAY_API_BASE: optional override of https://tetra98.com. Useful
#   for staging or if TetraPay rotates their API host.
# TETRAPAY_REQUEST_TIMEOUT_SECONDS: optional float, default 10. Same
#   shape as the NowPayments timeout; positive values only.
TETRAPAY_API_KEY=
# TETRAPAY_API_BASE=https://tetra98.com
# TETRAPAY_REQUEST_TIMEOUT_SECONDS=10

# Stage-13-Step-A: required-channel subscription gate. When set, every
# non-admin user must be a member of this channel before any handler
# (including /start) runs — they get a "Please join @channel" screen
# with a Join button + an "✅ I've joined" re-check button until
# Telegram's Bot API confirms membership. Leave UNSET to keep the
# bot fully open (back-compat default).
#
# REQUIRED_CHANNEL accepts either a public ``@username`` (e.g.
# ``@MeowAssist_Channel``) or a numeric ``-100…`` chat id for a
# private channel / supergroup. The bot must be added as an
# administrator of the channel — Telegram only lets bots query
# membership for chats they administer. If the bot isn't admin yet,
# the gate fails OPEN with a logged WARNING (so an operator
# bootstrapping the channel doesn't lock every user out).
#
# REQUIRED_CHANNEL_INVITE_LINK overrides the synthesised join URL.
# Leave unset for public ``@handle`` channels — we synthesise
# ``https://t.me/<handle>`` automatically. SET this to a join-request
# / private-invite URL (``https://t.me/+abcdefINVITE``) when
# REQUIRED_CHANNEL is a numeric private-channel id, otherwise the
# Join button is omitted (the user can still tap "I've joined" but
# the bot won't deep-link them to anywhere).
#
# Admins listed in ADMIN_USER_IDS always bypass the gate so the
# operator can never lock themselves out of their own bot.
REQUIRED_CHANNEL=
# REQUIRED_CHANNEL_INVITE_LINK=https://t.me/+abcdefINVITE

# Stage-13-Step-C — referral codes (user-to-user invites that credit
# both wallets on the invitee's first paid top-up). Three knobs:
#
# BOT_USERNAME — the bot's @handle without the leading @ (e.g.
# ``Meowassist_Ai_bot``). Used to synthesise the share deep-link
# ``https://t.me/<handle>?start=ref_<code>`` rendered on the
# /wallet → "Invite a friend" screen. Leave unset and the screen
# falls back to a copy-paste-only flow (the bare code + a
# /start ref_<code> instruction); the feature still works, just
# without a one-tap link.
#
# REFERRAL_BONUS_PERCENT — percentage of the invitee's first paid
# top-up credited to BOTH wallets (referrer + invitee). Defaults to
# 10 (i.e. 10%). Capped at REFERRAL_BONUS_MAX_USD per side. Non-finite
# / non-positive values fall back to the default with a logged WARNING.
#
# REFERRAL_BONUS_MAX_USD — per-side cap on the bonus. Defaults to $5.
# So a $20 first-top-up triggers 10% × $20 = $2 to each side; a $100
# first-top-up triggers $5 (the cap), not $10.
BOT_USERNAME=
REFERRAL_BONUS_PERCENT=10
REFERRAL_BONUS_MAX_USD=5
